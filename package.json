{
	"name": "hono-honeypot",
	"version": "1.3.3",
	"description": "Hono.js security middleware. Honeypot path blocker that stops vulnerability scanners (nuclei, nikto, sqlmap, dirbuster), bot crawlers, and brute-force probes. Mini WAF with optional IP strike and ban. Zero dependencies. Cloudflare Workers, Bun, Deno, Node.js, Vercel Edge, Fastly Compute.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"AGENTS.md"
	],
	"scripts": {
		"build": "tsup",
		"test": "bun test",
		"prepublishOnly": "bun run build && bun test"
	},
	"keywords": [
		"hono",
		"hono-middleware",
		"middleware",
		"honeypot",
		"security",
		"waf",
		"web-application-firewall",
		"firewall",
		"bot-protection",
		"bot-blocker",
		"scanner-blocker",
		"vulnerability-scanner",
		"request-filter",
		"ip-ban",
		"owasp",
		"edge",
		"edge-computing",
		"cloudflare-workers",
		"bun",
		"deno",
		"nodejs",
		"typescript"
	],
	"author": "ph33nx (https://github.com/ph33nx)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ph33nx/hono-honeypot.git"
	},
	"bugs": {
		"url": "https://github.com/ph33nx/hono-honeypot/issues"
	},
	"homepage": "https://github.com/ph33nx/hono-honeypot#readme",
	"peerDependencies": {
		"hono": "^4.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"hono": "^4.12.15",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=18"
	}
}
